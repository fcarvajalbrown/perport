{% set langCode = lang or 'es' %}
{% set L = strings[langCode] %}
<!DOCTYPE html>
<html lang="{{ langCode }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} · Felipe Carvajal Brown</title>
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Felipe Carvajal Brown">
    <meta property="og:title" content="{{ title }} · Felipe Carvajal Brown">
    {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
    <meta property="og:url" content="https://fcarvajalbrown.com{{ page.url }}">
    <meta property="og:image" content="https://fcarvajalbrown.com/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Felipe Carvajal Brown">
    <meta property="og:locale" content="{% if langCode == 'en' %}en_US{% else %}es_ES{% endif %}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} · Felipe Carvajal Brown">
    {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
    <meta name="twitter:image" content="https://fcarvajalbrown.com/og-image.png">
    <link rel="canonical" href="https://fcarvajalbrown.com{{ page.url }}">
    <link rel="icon" type="image/png" href="{{ '/logo.png' | bust }}">
    <link rel="stylesheet" href="{{ '/styles.css' | bust }}">
    {% if hreflangEs and hreflangEn %}
    <link rel="alternate" hreflang="es" href="https://fcarvajalbrown.com{{ hreflangEs }}">
    <link rel="alternate" hreflang="en" href="https://fcarvajalbrown.com{{ hreflangEn }}">
    <link rel="alternate" hreflang="x-default" href="https://fcarvajalbrown.com{{ hreflangEs }}">
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="{{ bodyClass }}">
    <nav class="site-nav">
        <div class="site-nav-inner">
            <a class="site-nav-brand" href="{{ L.nav[0].url }}" aria-label="{{ L.nav[0].label }}, Felipe Carvajal Brown">
                <img src="{{ '/logo.png' | bust }}" alt="" class="site-nav-logo" width="29" height="32" />
                <span class="site-nav-name">Felipe Carvajal Brown</span>
            </a>
            <button class="site-nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
            <ul class="site-nav-links">
                {% for item in L.nav %}
                <li><a href="{{ item.url }}"{% if page.url == item.url %} class="active" aria-current="page"{% endif %}>{{ item.label }}</a></li>
                {% endfor %}
                <li><a class="site-nav-lang" href="{{ altUrl or L.nav[0].url }}" title="{{ L.toggleTitle }}">{{ L.toggleLabel }}</a></li>
            </ul>
        </div>
    </nav>

    {{ content | safe }}

    <footer class="site-footer">
        <p>{{ L.footer }}</p>
    </footer>

    <script>
        (function () {
            var toggle = document.querySelector('.site-nav-toggle');
            var links = document.querySelector('.site-nav-links');
            if (!toggle || !links) return;
            toggle.addEventListener('click', function () {
                var open = links.classList.toggle('open');
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
        })();
    </script>
</body>
</html>
