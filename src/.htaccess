# Cache policy for the static site.
# Goal: never let a returning visitor run stale HTML that points at an old,
# since-fixed script. HTML always revalidates; hashed assets cache forever
# (their ?v=<hash> query changes whenever the file content changes).

<IfModule mod_headers.c>
    # HTML: always revalidate so the current asset hashes are picked up.
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # data.json: the background-refresh snapshot. Short cache so a cron update
    # becomes visible within ~10 min (script.js also fetches a 10-min-bucketed
    # URL so a stale CDN entry is bypassed rather than pinned for hours).
    <FilesMatch "^data\.json$">
        Header set Cache-Control "public, max-age=600"
    </FilesMatch>

    # Fingerprinted static assets: safe to cache long-term because the URL
    # carries a content hash (?v=...) that changes when the file changes.
    <FilesMatch "\.(css|js|png|webp|svg|woff2?|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
